# Copy this file to .env when running the bridge as its own project.
# Do not commit .env files.

MOCHAD_HOST=mochad
MOCHAD_PORT=1099

PUID=911
PGID=911
TZ=UTC
UMASK=022
ALLOW_ROOT=false

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PASSWORD_FILE=
MQTT_TLS_ENABLED=false
MQTT_TLS_CA_FILE=
MQTT_TLS_CERT_FILE=
MQTT_TLS_KEY_FILE=
MQTT_TLS_KEY_PASSWORD=
MQTT_TLS_KEY_PASSWORD_FILE=
MQTT_DOCKER_NETWORK=mqtt

MQTT_BASE_TOPIC=x10
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_DISCOVERY_ENABLED=true
BRIDGE_CONFIG_FILE=/config/bridge.json
BRIDGE_CONFIG_RELOAD_INTERVAL_SECONDS=5
DISCOVERY_CLEANUP=false
DISCOVERY_REGISTRY_PATH=/config/discovery_registry.json
ENABLE_MAINTENANCE_BUTTONS=false

# Optional fields: address:name:type:command_repeats:repeat_delay_ms
X10_DEVICES=A1:Living Room Lamp:light,A2:Coffee Maker:switch,A3:Door Chime:chime
X10_USE_FRIENDLY_NAMES=true
X10_HOUSECODES=
LOG_LEVEL=INFO
BRIDGE_DEBUG_WIRE=false
BRIDGE_HEALTH_MAX_AGE_SECONDS=30
